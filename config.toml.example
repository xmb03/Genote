# =============================================================================
# Flat config (simple) — all settings at root level.
# Uncomment and adjust if you don't need profiles.
# =============================================================================
# model = "your-model-name"
# api_url = "http://127.0.0.1:11434/api/generate"
# notes_dir = "~/path/to/your/notes"
# lang = "en"
# note_size = "small"
# notes_count = 7
# use_covered_topics = false

# =============================================================================
# Profile-based config — define multiple environments.
# Global fields at root level apply to ALL profiles as defaults.
# =============================================================================

# Default profile used when --profile is not passed on CLI
default = "work"

# Global defaults (applied to every profile before merging profile-specific values)
model = "llama3"
api_url = "http://127.0.0.1:11434/api/generate"
lang = "en"

# --- Profile: work ---
[profile.work]
notes_dir = "~/work-notes"
note_size = "big"
notes_count = 10

# --- Profile: home ---
[profile.home]
notes_dir = "~/personal-notes"
note_size = "small"
notes_count = 5
model = "mistral"  # override global model for this profile

# --- Profile: server ---
[profile.server]
api_url = "http://192.168.1.50:11434/api/generate"
notes_dir = "~/server-notes"
lang = "ru"
note_size = "big"
